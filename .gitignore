# Build artifacts
bin/
obj/

# IDE
.vs/
.vscode/
.idea/
.claude/
*.user
*.suo

# .NET
*.swp
*.userprefs
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]uild/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
project.lock.json
project.fragment.lock.json
artifacts/

# Local secrets — NEVER commit
appsettings.Development.json
appsettings.Local.json
*.pfx
*.env
.env
secrets.json

# Phase 11.1 — ASP.NET Data Protection key ring. Contains the master keys
# that decrypt every dbo.AppSettings.EncryptedValue. Lose these and every
# stored secret is gone; commit them and every secret is on GitHub. Back
# up out-of-band alongside the DB.
.dp-keys/
src/ReceivingOps.Web/.dp-keys/
# Phase-cutover key snapshots — same secrets as .dp-keys/, never commit.
.dp-keys-backup*/
src/ReceivingOps.Web/.dp-keys-backup*/

# OS
.DS_Store
Thumbs.db

# Local DB backups (manual snapshots; large + machine-specific)
db_backup/

# Dev server stdout capture (from `dotnet run | tee dev-server.log`)
dev-server.log
dev-server.err.log

# Phase 8.4 — export-generated workbooks. The exports/ dirs themselves are
# checked in via .gitkeep so the runtime paths exist on fresh clones, but
# their contents are operator data — never commit. Two possible locations
# depending on how the app is launched:
#   - exports/                          (when launched from repo root)
#   - src/ReceivingOps.Web/exports/     (dotnet run resolves via AppContext.BaseDirectory)
exports/*
!exports/.gitkeep
src/ReceivingOps.Web/exports/*
!src/ReceivingOps.Web/exports/.gitkeep

# Phase 12.5 — PO Excel import staging. Files land in
# {ContentRootPath}/imports/staging/{runId}.xlsx between upload and the
# Hangfire worker's commit. Same .gitkeep convention as exports/.
imports/staging/*
!imports/staging/.gitkeep
src/ReceivingOps.Web/imports/staging/*
!src/ReceivingOps.Web/imports/staging/.gitkeep

# Path B — delivery-order.frx is now source-controlled (Stage 8 close).
# The Designer-edited version is the authoritative layout; the runtime
# template builder remains as a bootstrap path for fresh environments,
# but designer edits in source are the truth. *.frx.tmp.* are atomic-
# write artifacts from EnsureFrxExists and never want to be tracked.
src/ReceivingOps.Web/Reports/*.frx.tmp.*

# Path B Stage 7 — dsv-parity-capture.ps1 writes side-by-side HTML + PDF
# snapshots here for visual review. Snapshots are runtime artifacts; the
# script itself is committed.
tools/parity-out/
