@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/login.css">
</head>
<body>

<div class="login-shell">

    <!-- LEFT PANEL: Brand -->
    <div class="brand-panel">
        <div class="brand-top">
            <div class="brand-logo">
                <i class="bi bi-box-seam"></i>
            </div>
            <div class="brand-wordmark">Receiving<span>OPS v3.2</span></div>
        </div>

        <div class="brand-hero">
            <h1>Run inbound<br><b>like clockwork.</b></h1>
            <p>One console for every pull sheet, every warehouse, every hour. Track receipts in real time, close pulls with a signature, and never lose a unit again.</p>
        </div>

        <div>
            <div class="brand-stats">
                <div class="brand-stat">
                    <div class="brand-stat-label">Active Pulls</div>
                    <div class="brand-stat-value">12 <small>today</small></div>
                </div>
                <div class="brand-stat">
                    <div class="brand-stat-label">Warehouses</div>
                    <div class="brand-stat-value">3 <small>online</small></div>
                </div>
                <div class="brand-stat">
                    <div class="brand-stat-label">Throughput</div>
                    <div class="brand-stat-value">6.1k <small>units / 24h</small></div>
                </div>
            </div>

            <div class="brand-bottom" style="margin-top: 32px;">
                <div class="live-indicator">System operational</div>
                <div>v3.2 · build 4172</div>
            </div>
        </div>
    </div>

    <!-- RIGHT PANEL: Form -->
    <div class="form-panel">
        <div class="form-panel-top">
            <div class="theme-switch" role="group" aria-label="Theme">
                <button type="button" class="theme-swatch light active" data-theme="light"    title="Light Paper"></button>
                <button type="button" class="theme-swatch midnight"     data-theme="midnight" title="Midnight"></button>
                <button type="button" class="theme-swatch slate"        data-theme="slate"    title="Slate"></button>
            </div>
        </div>

        <div class="form-wrap">
            <div class="form-eyebrow">Welcome back</div>
            <h2 class="form-title">Sign in</h2>
            <p class="form-subtitle">Continue to your receiving console.</p>

            <div class="demo-credentials">
                <div class="demo-credentials-head">
                    <span class="demo-credentials-label">Demo Mode</span>
                    <button type="button" class="demo-credentials-fill" id="demo-fill">Fill</button>
                </div>
                <div class="demo-credentials-body">
                    User <b>swattana</b> / <b>demo1234</b> · or <b>sadmin</b> / <b>admin</b>
                </div>
            </div>

            <div class="form-error" id="form-error">
                <i class="bi bi-exclamation-circle"></i>
                <span id="form-error-msg">Invalid credentials</span>
            </div>

            <form id="login-form" novalidate>
                <div class="form-group">
                    <label for="username">Username</label>
                    <div class="input-with-icon">
                        <i class="bi bi-person"></i>
                        <input type="text" class="form-control" id="username" placeholder="username" autocomplete="username" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="input-with-icon">
                        <i class="bi bi-lock"></i>
                        <input type="password" class="form-control" id="password" placeholder="••••••••" autocomplete="current-password" required>
                        <button type="button" class="toggle-pw" id="toggle-pw" aria-label="Show password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group">
                    <label for="warehouse">Sign in to warehouse</label>
                    <select class="form-select" id="warehouse" required disabled>
                        <option value="">Enter username first…</option>
                    </select>
                    <span class="help" id="warehouse-help" style="font-family: 'Roboto Mono', monospace; font-size: 11px; color: var(--text-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.08em; padding-left: 2px;">
                        Warehouses unlock based on your assignments
                    </span>
                </div>

                <div class="options-row">
                    <label class="remember-check">
                        <input type="checkbox" id="remember" checked>
                        <span>Keep me signed in</span>
                    </label>
                    <a href="#" class="forgot-link">Forgot password?</a>
                </div>

                <button type="submit" class="btn-signin" id="btn-signin">
                    <span class="label">Sign in</span>
                    <span class="spinner"></span>
                    <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <div class="form-foot">
                Receiving v3.2 · Anthropic Co. © 2026
            </div>
        </div>
    </div>

</div>

<script src="~/js/login.js"></script>
</body>
</html>
