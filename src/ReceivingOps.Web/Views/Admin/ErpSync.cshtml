@{
    ViewData["Title"] = "ERP Sync";
    ViewData["PageId"] = "admin-erp-sync";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ERP Sync · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/exports.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/pagination.css" asp-append-version="true">
</head>
<body data-app-page="admin-erp-sync">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div>
                <div class="page-eyebrow">Admin · Integration</div>
                <h1 class="page-title">ERP Sync</h1>
                <p class="page-subtitle">History of ERP-to-Receivx sync runs. Recurring fires hourly; manual triggers run on demand.</p>
            </div>
            <div class="page-actions">
                <button class="btn btn-outline-secondary" id="btn-refresh" title="Refresh now">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
                <button class="btn btn-primary" id="btn-sync-now" title="Trigger a manual sync">
                    <i class="bi bi-arrow-repeat"></i> Sync now
                </button>
            </div>
        </div>

        <div class="section">
            <div class="section-head">
                <div class="section-title">
                    <i class="bi bi-clock-history"></i> <span>Recent runs</span>
                </div>
                <div class="meta-line" id="list-count">0 records</div>
            </div>

            <div id="state-banner" class="auto-refresh-banner" hidden>
                <i class="bi bi-arrow-clockwise spin"></i>
                <span id="state-banner-msg">A sync is in flight — auto-refreshing every 5 s.</span>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 150px;">Started</th>
                            <th style="width: 90px;">Trigger</th>
                            <th style="width: 110px;">Status</th>
                            <th style="width: 180px;">Operator</th>
                            <th style="width: 100px;" class="num">Created</th>
                            <th style="width: 100px;" class="num">Updated</th>
                            <th style="width: 100px;" class="num">Skipped</th>
                            <th style="width: 100px;" class="num">Errors</th>
                            <th style="width: 90px;" class="num">Elapsed</th>
                            <th>RunId / Detail</th>
                        </tr>
                    </thead>
                    <tbody id="rows"></tbody>
                </table>
            </div>

            <div id="empty" class="empty-state" hidden>
                <i class="bi bi-inbox"></i>
                <div>No sync runs yet. Click <b>Sync now</b> or wait for the hourly schedule.</div>
            </div>

            <div id="pagination-host" class="pagination-host"></div>
        </div>
    </div>
</div>

<!-- Sync-now modal (admin warehouse picker + backfill window) -->
<div class="modal fade" id="syncModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Trigger ERP sync
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">
                    Pulls planning data from <code>BPI_PRS</code> for the chosen warehouse.
                    Closed pulls are protected; operator-edited fields are preserved.
                </p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Warehouse *</label>
                        <select class="form-select" id="sync-warehouse"></select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Backfill days</label>
                        <input type="number" class="form-control" id="sync-backfill-days" value="30" min="1" max="365">
                    </div>
                </div>
                <div id="sync-status" class="mt-3" hidden></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="sync-cancel">Cancel</button>
                <button type="button" class="btn btn-primary" id="sync-trigger">Start sync</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/app-nav.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/components/pagination.js" asp-append-version="true"></script>
<script src="~/js/admin-erp-sync.js" asp-append-version="true"></script>
</body>
</html>
