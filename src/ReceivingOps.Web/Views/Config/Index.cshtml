@{
    ViewData["Title"] = "Settings";
    ViewData["PageId"] = "config";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings · Receiving Operations</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/config.css" asp-append-version="true">
</head>
<body data-app-page="config">
<!-- ===== BODY:main (from config.html) ===== -->

<div class="app">
  <!-- nav injected by app-nav.js -->

  <div class="page-wrap">

    <div class="page-head">
      <div class="page-eyebrow">Preferences</div>
      <h1 class="page-title">Settings</h1>
      <p class="page-subtitle">Personalize how the receiving console looks and feels for you.</p>
    </div>

    <!-- ACCOUNT -->
    <div class="section">
      <div class="section-head">
        <div class="section-title-block">
          <div class="eyebrow">Account</div>
          <div class="section-title">Your profile</div>
          <div class="section-desc">Signed-in identity and current session details.</div>
        </div>
      </div>

      <div class="account-card">
        <div class="account-avatar" id="acc-avatar">SW</div>
        <div style="position: relative; z-index: 1;">
          <div class="account-info-name" id="acc-name">S. Wattana</div>
          <div class="account-info-role" id="acc-role">Inbound Supervisor</div>
          <div class="account-info-meta" id="acc-meta">Signed in 14:32 ICT · 18 Mar 2026</div>
        </div>
      </div>

      <div class="account-grid">
        <div class="account-row">
          <span class="label">Username</span>
          <span class="value" id="acc-username">swattana</span>
        </div>
        <div class="account-row">
          <span class="label">Warehouse</span>
          <span class="value" id="acc-warehouse">WH-01 · Bangkok Main</span>
        </div>
        <div class="account-row">
          <span class="label">Role</span>
          <span class="value" id="acc-role2">Inbound Supervisor</span>
        </div>
        <div class="account-row">
          <span class="label">Last Sign-in</span>
          <span class="value" id="acc-signin">Today, 14:32</span>
        </div>
      </div>
    </div>

    <!-- THEME -->
    <div class="section">
      <div class="section-head">
        <div class="section-title-block">
          <div class="eyebrow">Appearance</div>
          <div class="section-title">Theme</div>
          <div class="section-desc">Choose a color scheme. Applies instantly across all pages.</div>
        </div>
      </div>

      <div class="theme-grid">
        <button class="theme-card" data-theme="light">
          <div class="theme-preview light">
            <div class="theme-preview-bar"></div>
            <div class="theme-preview-dots">
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
            </div>
          </div>
          <div class="theme-name">Light Paper <i class="bi bi-check2 check"></i></div>
          <div class="theme-desc">Warm cream · daylight</div>
        </button>
        <button class="theme-card" data-theme="midnight">
          <div class="theme-preview midnight">
            <div class="theme-preview-bar"></div>
            <div class="theme-preview-dots">
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
            </div>
          </div>
          <div class="theme-name">Midnight <i class="bi bi-check2 check"></i></div>
          <div class="theme-desc">Dark · night shift</div>
        </button>
        <button class="theme-card" data-theme="slate">
          <div class="theme-preview slate">
            <div class="theme-preview-bar"></div>
            <div class="theme-preview-dots">
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
              <span class="theme-preview-dot"></span>
            </div>
          </div>
          <div class="theme-name">Slate <i class="bi bi-check2 check"></i></div>
          <div class="theme-desc">Cool grey · corporate</div>
        </button>
      </div>
    </div>

    <!-- NAV -->
    <div class="section">
      <div class="section-head">
        <div class="section-title-block">
          <div class="eyebrow">Navigation</div>
          <div class="section-title">Menu bar</div>
          <div class="section-desc">Position and behavior of the main navigation across the app.</div>
        </div>
      </div>

      <div class="setting-row">
        <div class="setting-info">
          <div class="setting-name">Position</div>
          <div class="setting-help">Horizontal puts the nav across the top. Vertical pins it to the left side.</div>
        </div>
        <div class="toggle-group" id="nav-position">
          <button class="toggle-option" data-value="horizontal">
            <i class="bi bi-layout-three-columns"></i> Horizontal
          </button>
          <button class="toggle-option" data-value="vertical">
            <i class="bi bi-layout-sidebar"></i> Vertical
          </button>
        </div>
      </div>

      <div class="setting-row">
        <div class="setting-info">
          <div class="setting-name">Behavior</div>
          <div class="setting-help">Sticky stays at the top while you scroll. Auto-hide gets out of the way. Static scrolls away with the page.</div>
        </div>
        <div class="toggle-group" id="nav-behavior">
          <button class="toggle-option" data-value="sticky">
            <i class="bi bi-pin-angle"></i> Sticky
          </button>
          <button class="toggle-option" data-value="auto-hide">
            <i class="bi bi-eye-slash"></i> Auto-hide
          </button>
          <button class="toggle-option" data-value="static">
            <i class="bi bi-arrow-down-circle"></i> Static
          </button>
        </div>
      </div>
    </div>

    <!-- ADMIN — Configuration editor (Phase 11.2). Replaces the v2.1.9
         read-only Email-test diagnostic. Hidden unless current user is
         admin (config.js toggles via /api/auth/me); all endpoints are
         [Authorize(Roles = "admin")] so the UI gate is convenience only.
         Tab switching + per-tab renderers live in config-editor.js. -->
    <div class="section admin-only" data-admin-only hidden>
      <div class="section-head">
        <div class="section-title-block">
          <div class="eyebrow">Configuration · Admin only</div>
          <div class="section-title">System settings</div>
          <div class="section-desc">Edit runtime configuration. Changes require an application restart to take effect.</div>
        </div>
      </div>

      <div id="config-editor-root" class="config-editor">
        <div class="config-tabs" role="tablist">
          <button class="config-tab is-active" data-tab="Smtp" role="tab" type="button">
            <i class="bi bi-envelope"></i><span>Email</span>
          </button>
          <button class="config-tab" data-tab="ErpDb" role="tab" type="button">
            <i class="bi bi-database"></i><span>ERP Connection</span>
          </button>
          <button class="config-tab" data-tab="ErpSync" role="tab" type="button">
            <i class="bi bi-clock"></i><span>Sync Schedule</span>
          </button>
          <button class="config-tab" data-tab="Exports" role="tab" type="button">
            <i class="bi bi-box-arrow-down"></i><span>Exports</span>
          </button>
        </div>

        <div class="config-panel" data-panel="Smtp" id="config-panel-Smtp">
          <div class="config-panel-loading">Loading…</div>
        </div>
        <div class="config-panel" data-panel="ErpDb" id="config-panel-ErpDb" hidden>
          <div class="config-panel-loading">Loading…</div>
        </div>
        <div class="config-panel" data-panel="ErpSync" id="config-panel-ErpSync" hidden>
          <div class="config-panel-loading">Loading…</div>
        </div>
        <div class="config-panel" data-panel="Exports" id="config-panel-Exports" hidden>
          <div class="config-panel-loading">Loading…</div>
        </div>
      </div>

      <div id="restart-banner" class="restart-banner" hidden role="status" aria-live="polite">
        <i class="bi bi-exclamation-triangle"></i>
        <div class="restart-banner-text">
          <strong>Restart required</strong>
          <p>Configuration saved. Restart the application to apply changes.</p>
        </div>
        <button class="btn" id="dismiss-restart-banner" type="button">Dismiss</button>
      </div>
    </div>

    <!-- DANGER -->
    <div class="section">
      <div class="section-head">
        <div class="section-title-block">
          <div class="eyebrow">Session</div>
          <div class="section-title">Sign out &amp; reset</div>
          <div class="section-desc">Manage your session and reset preferences if something feels off.</div>
        </div>
      </div>

      <div class="setting-row">
        <div class="setting-info">
          <div class="setting-name">Reset preferences</div>
          <div class="setting-help">Restore theme, nav, and saved filters to defaults. Your account isn't affected.</div>
        </div>
        <button class="btn" id="btn-reset"><i class="bi bi-arrow-counterclockwise"></i> Reset to defaults</button>
      </div>

      <div class="danger-zone">
        <div class="danger-zone-info">
          <div class="label">Danger zone</div>
          <div class="help">Signing out clears your session and returns you to the login screen.</div>
        </div>
        <button class="btn btn-danger" id="btn-signout"><i class="bi bi-box-arrow-right"></i> Sign out</button>
      </div>
    </div>

    <!-- Save bar -->
    <div class="save-bar" id="save-bar">
      <span class="save-bar-msg" id="save-msg">All changes saved</span>
      <div class="save-bar-actions">
        <button class="btn" id="btn-discard" style="display:none;"><i class="bi bi-x"></i> Discard</button>
        <button class="btn btn-primary" id="btn-save"><i class="bi bi-check2"></i> Save</button>
      </div>
    </div>
  </div>
</div>

<div class="toast-host">
  <div class="custom-toast" id="toast">
    <div class="icon-wrap">✓</div>
    <div class="msg" id="toast-msg">Settings saved</div>
  </div>
</div>



<script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/app-nav.js" asp-append-version="true"></script>
<script src="~/js/config.js" asp-append-version="true"></script>
<script src="~/js/config-editor.js" asp-append-version="true"></script>

</body>
</html>