@{
    ViewData["Title"] = "Pull Controller";
    ViewData["PageId"] = "pull";
    Layout = null;  // The mockup owns its own theme stylesheet + DOM structure.
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pull Controller · Receiving Operations</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.jsdelivr.net/npm/xlsx@@0.18.5/dist/xlsx.full.min.js"></script>

    <link rel="stylesheet" href="~/css/dashboard.css">
</head>
<body data-app-page="pull">

<div class="app">

    <!-- TOP BAR -->
    <header class="topbar">
        <div class="brand">
            <div class="brand-mark">Pull Controller<span>v2.0</span></div>
            <div class="brand-path">Operations <b>/</b> Inbound <b>/</b> Pull Requests</div>
        </div>
        <div class="topbar-right">
            <div class="theme-switch" role="group" aria-label="Theme">
                <button type="button" class="theme-swatch light active" data-theme="light"    title="Light Paper"></button>
                <button type="button" class="theme-swatch midnight"     data-theme="midnight" title="Midnight"></button>
                <button type="button" class="theme-swatch slate"        data-theme="slate"    title="Slate"></button>
            </div>
            <div class="status-pill">
                <span class="pulse"></span>
                <span>Live · @DateTime.UtcNow.AddHours(7).ToString("HH:mm") ICT · @DateTime.UtcNow.AddHours(7).ToString("dd MMM yyyy")</span>
            </div>
            <div class="user-chip">
                <span>@(User.FindFirst("displayName")?.Value ?? "Guest")</span>
                <span class="avatar">@(GetInitials(User.FindFirst("displayName")?.Value ?? ""))</span>
            </div>
        </div>
    </header>

    <!-- SUMMARY STRIP -->
    <div class="summary-strip">
        <div class="summary-cell">
            <span class="summary-label">Total Pulls</span>
            <span class="summary-value" id="sum-total">—</span>
            <span class="summary-sub">across all warehouses</span>
        </div>
        <div class="summary-cell">
            <span class="summary-label">In Progress</span>
            <span class="summary-value" id="sum-inprogress">—</span>
            <span class="summary-sub warn">due today</span>
        </div>
        <div class="summary-cell">
            <span class="summary-label">Ready to Close</span>
            <span class="summary-value" id="sum-ready">—</span>
            <span class="summary-sub ok">fully received · awaiting signature</span>
        </div>
        <div class="summary-cell">
            <span class="summary-label">Items · Today</span>
            <span class="summary-value" id="sum-items">— <small>SKUs</small></span>
            <span class="summary-sub">across filtered pulls</span>
        </div>
        <div class="summary-cell">
            <span class="summary-label">Throughput · Filtered</span>
            <span class="summary-value" id="sum-thru">— <small>units</small></span>
            <span class="summary-sub ok" id="sum-thru-sub">— of expected</span>
        </div>
    </div>

    <!-- TOOLBAR -->
    <div class="toolbar">
        <div class="field-group">
            <span class="field-label">Warehouse</span>
            <select class="form-select" id="wh-filter">
                <option value="all">All warehouses</option>
                <option value="WH-01">WH-01 · Bangkok Main</option>
                <option value="WH-02">WH-02 · Chonburi</option>
                <option value="WH-03">WH-03 · Rayong</option>
            </select>
        </div>
        <div class="field-group">
            <span class="field-label">Date Range</span>
            <select class="form-select" id="date-filter">
                <option value="all">All dates</option>
                <option value="today">Today</option>
                <option value="last_2_days" selected>Last 2 days</option>
                <option value="yesterday">Yesterday</option>
                <option value="this_week">This week</option>
                <option value="last_week">Last week</option>
                <option value="custom">Custom range…</option>
            </select>
        </div>
        <div class="field-group">
            <span class="field-label">Lock (§3.5)</span>
            <select class="form-select" id="lock-filter" title="Filter by per-pull PO allocation mode">
                <option value="all">All pulls</option>
                <option value="locked">Locked only</option>
                <option value="unlocked">Unlocked only</option>
            </select>
        </div>
        <div class="toolbar-spacer"></div>
        <div class="search-box field-group">
            <span class="field-label">Search</span>
            <div style="position: relative;">
                <i class="bi bi-search"></i>
                <input id="search-input" class="form-control" placeholder="Pull #, warehouse, operator…">
            </div>
        </div>
        <button type="button" class="btn btn-outline-secondary" id="btn-export">
            <i class="bi bi-download me-1"></i> Export
        </button>
        @* Phase 10.4 — manual ERP sync trigger. Hidden by default; JS reveals
           when /api/auth/me reports role=admin. *@
        <button type="button" class="btn btn-outline-secondary" id="btn-erp-sync" style="display: none;">
            <i class="bi bi-arrow-repeat me-1"></i> <span id="btn-erp-sync-label">Sync ERP</span>
        </button>
        <button type="button" class="btn btn-primary" id="btn-new-pull">
            <i class="bi bi-plus-lg me-1"></i> New Pull
        </button>
    </div>

    <div class="custom-date-row" id="custom-date-row">
        <div class="field-group">
            <span class="field-label">From</span>
            <input type="date" class="form-control" id="date-from">
        </div>
        <span class="date-arrow"><i class="bi bi-arrow-right"></i></span>
        <div class="field-group">
            <span class="field-label">To</span>
            <input type="date" class="form-control" id="date-to">
        </div>
        <button type="button" class="btn btn-outline-secondary" id="date-apply"><i class="bi bi-funnel me-1"></i> Apply</button>
        <button type="button" class="btn btn-outline-secondary" id="date-clear"><i class="bi bi-x me-1"></i> Clear</button>
    </div>

    <!-- KANBAN -->
    <div class="kanban-wrap">
        <div class="kanban" id="kanban"></div>
    </div>

    <footer class="footer">
        <div class="footer-legend">
            <span class="legend-dot pending">Pending</span>
            <span class="legend-dot in_progress">In Progress</span>
            <span class="legend-dot fully_received">Fully Received</span>
            <span class="legend-dot closed">Closed</span>
        </div>
        <div>Click any card to see details</div>
    </footer>
</div>

<!-- DETAIL DRAWER -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="detailDrawer" aria-labelledby="drawerLabel">
    <div class="offcanvas-header d-flex justify-content-between align-items-start">
        <div>
            <div class="drawer-eyebrow" id="d-eyebrow">Pull Sheet Detail</div>
            <div class="drawer-title" id="d-title">—</div>
            <div class="drawer-subtitle" id="d-subtitle">—</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>

    <div class="offcanvas-body">
        <div class="drawer-section">
            <div class="drawer-section-title">Progress</div>
            <div class="progress-block" id="d-progress-block">
                <div class="progress-head">
                    <div class="progress-pct"><span id="d-pct">0</span><small>% complete</small></div>
                    <div class="progress-status-pill in_progress" id="d-status-pill">In Progress</div>
                </div>
                <div class="progress-track-large">
                    <div class="progress-fill-large in_progress" id="d-progress-fill" style="width: 0%"></div>
                </div>
                <div class="progress-foot">
                    <span>Started <b id="d-started">—</b></span>
                    <span>ETA <b id="d-eta">—</b></span>
                </div>
            </div>
        </div>

        <div class="drawer-section">
            <div class="drawer-section-title">Item Summary</div>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-card-label">Items</div>
                    <div class="stat-card-value" id="d-items">— <small>SKUs</small></div>
                    <div class="stat-card-sub" id="d-items-sub">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">Expected</div>
                    <div class="stat-card-value" id="d-expected">— <small>units</small></div>
                    <div class="stat-card-sub" id="d-expected-sub">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">Received</div>
                    <div class="stat-card-value" id="d-received">— <small>units</small></div>
                    <div class="stat-card-sub" id="d-received-sub">—</div>
                </div>
                <div class="stat-card">
                    <div class="stat-card-label">Outstanding</div>
                    <div class="stat-card-value" id="d-outstanding">— <small>units</small></div>
                    <div class="stat-card-sub" id="d-outstanding-sub">—</div>
                </div>
            </div>
        </div>

        <!-- v2.1 Phase 6.3 — PullItem admin grid -->
        <div class="drawer-section">
            <div class="drawer-section-title d-flex justify-content-between align-items-center">
                <span>Items <span class="text-muted small" id="d-items-count"></span></span>
                <button type="button" class="btn btn-sm btn-outline-primary" id="d-add-item">
                    <i class="bi bi-plus-lg me-1"></i> Add item
                </button>
            </div>
            <div class="items-table-wrap">
                <table class="table items-table mb-0" id="d-items-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Description</th>
                            <th>Vendor</th>
                            <th>Tag</th>
                            <th>Status</th>
                            <th class="text-end">Windows</th>
                            @* Phase 9.1 — ERP-sourced extended fields. Visually grouped via .erp-col (subtle bg + left border on first). *@
                            <th class="erp-col">Family</th>
                            <th class="erp-col">From Sub</th>
                            <th class="erp-col">To Sub</th>
                            <th class="erp-col">Trial</th>
                            <th class="erp-col">Loc</th>
                            <th class="erp-col">Phase</th>
                            <th class="erp-col">Special</th>
                            <th class="actions-col"></th>
                        </tr>
                    </thead>
                    <tbody id="d-items-tbody"></tbody>
                </table>
                <div id="d-items-empty" class="items-empty d-none">No items yet — click "Add item" to seed one.</div>
            </div>
        </div>

        <div class="drawer-section">
            <div class="drawer-section-title">Timeline</div>
            <div class="timeline">
                <div class="timeline-row">
                    <span class="timeline-label">First Receipt</span>
                    <span class="timeline-value" id="d-first">—</span>
                </div>
                <div class="timeline-row">
                    <span class="timeline-label">Last Activity</span>
                    <span class="timeline-value" id="d-last">—</span>
                </div>
                <div class="timeline-row">
                    <span class="timeline-label">Elapsed</span>
                    <span class="timeline-value" id="d-elapsed">—</span>
                </div>
                <div class="timeline-row">
                    <span class="timeline-label">Operator</span>
                    <span class="timeline-value" id="d-operator">—</span>
                </div>
            </div>
        </div>

        <!-- §3.5 / §7.15 — lock mode + linked POs.  v2.1 Hour Cap adds the hour-cap row. -->
        <div class="drawer-section">
            <div class="drawer-section-title">Strict mode (§3.5 · §7.1 v2.1)</div>
            <div class="timeline">
                <div class="timeline-row">
                    <span class="timeline-label">PO allocation</span>
                    <span class="timeline-value" id="d-lock-mode">—</span>
                </div>
                <div class="timeline-row">
                    <span class="timeline-label">Hour cap</span>
                    <span class="timeline-value" id="d-hcap-mode">—</span>
                </div>
                <div class="timeline-row">
                    <span class="timeline-label">Linked POs</span>
                    <span class="timeline-value">
                        <a id="d-linked-pos-link" href="#" target="_blank" rel="noopener" style="text-decoration: none;">
                            <span id="d-linked-pos">—</span>
                        </a>
                    </span>
                </div>
            </div>
        </div>

        <!-- v2.x — close authorization (signature + signer + timestamp).
             Shown only when pull.status === 'closed'; JS hides the section
             otherwise. closeNote is deferred (see CLAUDE.md v2.x backlog). -->
        <section class="close-auth-section drawer-section" id="d-close-auth" style="display: none;">
            <div class="drawer-section-title">
                <i class="bi bi-shield-check me-1"></i> Close authorization
            </div>
            <dl class="close-auth-grid">
                <dt>Closed by</dt>
                <dd>
                    <div class="closer-name" id="d-closer-name">—</div>
                    <div class="closer-role" id="d-closer-role"></div>
                </dd>
                <dt>Closed at</dt>
                <dd id="d-close-time">—</dd>
            </dl>
            <div class="signature-card">
                <div class="signature-label">Signature</div>
                <div class="signature-canvas" id="d-signature-canvas"></div>
                <div class="signature-actions">
                    <button type="button" class="download-sig" id="d-download-sig">
                        <i class="bi bi-download me-1"></i> Download PNG
                    </button>
                </div>
            </div>
        </section>
    </div>

    <div class="offcanvas-footer">
        <span class="offcanvas-footer-hint">Press <kbd>↵</kbd> open · <kbd>ESC</kbd> close</span>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary" id="d-edit" title="Edit pull header (date / ETA / notes)">
                <i class="bi bi-pencil me-1"></i> Edit details
            </button>
            <button type="button" class="btn btn-primary" id="d-launch">
                <i class="bi bi-box-arrow-up-right me-1"></i> Open in Receiving v3.2
            </button>
        </div>
    </div>
</div>

<!-- ============ PULL CREATE / EDIT MODAL (§3.5 / §7.15) ============ -->
<div class="modal fade" id="pullModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-clipboard-plus me-2"></i>
                    <span id="pm-title">New Pull</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Pull # *</label>
                        <input type="text" class="form-control" id="pm-pull-number" placeholder="PL-XXXX">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Warehouse *</label>
                        <select class="form-select" id="pm-warehouse"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Pull date *</label>
                        <input type="date" class="form-control" id="pm-pull-date">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">ETA</label>
                        <input type="text" class="form-control" id="pm-eta" placeholder="e.g. 14:00">
                    </div>
                    <!-- v2.x Phase 7.1 — vendor invoice / delivery-batch ID. Optional; surfaces on the DO render in Phase 7.2+. -->
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Reference</label>
                        <input type="text" class="form-control" id="pm-reference" maxlength="64" placeholder="e.g. INV-2026-0042 (optional)">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Notes</label>
                        <textarea class="form-control" id="pm-notes" rows="2" placeholder="Optional"></textarea>
                    </div>
                    <div class="col-12">
                        <div class="lock-toggle-card" id="pm-lock-card">
                            <label class="lock-toggle-label">
                                <input type="checkbox" id="pm-lock-po-by-pull" checked>
                                <span class="lock-toggle-text">
                                    <span class="lock-toggle-title"><i class="bi bi-lock-fill"></i> Lock PO allocation to this pull</span>
                                    <span class="lock-toggle-help" id="pm-lock-help">
                                        When enabled, only POs explicitly linked to this pull can be received against.
                                        Cannot be changed after creation (§7.15 / §3.5 Mode B).
                                    </span>
                                </span>
                            </label>
                        </div>
                    </div>
                    <!-- v2.1 Hour Cap (§7.1 v2.1) — strict by default, immutable after create. -->
                    <div class="col-12">
                        <div class="lock-toggle-card" id="pm-hcap-card">
                            <label class="lock-toggle-label">
                                <input type="checkbox" id="pm-lock-hour-cap" checked>
                                <span class="lock-toggle-text">
                                    <span class="lock-toggle-title"><i class="bi bi-clock-fill"></i> Strict per-hour capacity</span>
                                    <span class="lock-toggle-help" id="pm-hcap-help">
                                        When enabled, receives that would exceed a window's expected qty are rejected.
                                        Uncheck for vendors that over-ship intentionally. Immutable after creation.
                                    </span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="pm-save">Create pull</button>
            </div>
        </div>
    </div>
</div>

<!-- ============ v2.1 PHASE 6.3 — ADD ITEM MODAL ============ -->
<!-- Single POST to /items with embedded windows. Windows mini-table is a -->
<!-- draft until Save; rows can be added/removed freely. -->
<div class="modal fade" id="itemAddModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-square me-2"></i>
                    Add item to <span id="iam-pull-label">—</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Item code *</label>
                        <input type="text" class="form-control" id="iam-item-code" placeholder="e.g. WIDGET-100" maxlength="64">
                    </div>
                    <div class="col-md-8">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Description *</label>
                        <input type="text" class="form-control" id="iam-description" maxlength="255">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Vendor code</label>
                        <input type="text" class="form-control" id="iam-vendor-code" maxlength="64">
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Vendor name</label>
                        <input type="text" class="form-control" id="iam-vendor-name" maxlength="160">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Tag</label>
                        <select class="form-select" id="iam-tag">
                            <option value="">—</option>
                            <option value="pcba">pcba</option>
                            <option value="swap">swap</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Remark</label>
                        <input type="text" class="form-control" id="iam-remark" maxlength="255">
                    </div>
                    <div class="col-12">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="form-label small text-muted text-uppercase fw-semibold mb-0" style="letter-spacing: 0.1em;">Windows *</label>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="iam-add-window">
                                <i class="bi bi-plus-lg me-1"></i> Add window
                            </button>
                        </div>
                        <table class="table wm-add-windows-table mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 120px;">Hour</th>
                                    <th>Expected qty</th>
                                    <th class="actions-col"></th>
                                </tr>
                            </thead>
                            <tbody id="iam-windows-tbody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="iam-save">Create item</button>
            </div>
        </div>
    </div>
</div>

<!-- ============ v2.1 PHASE 6.3 — EDIT ITEM MODAL (header only) ============ -->
<!-- ItemCode is the natural key and intentionally disabled. Windows are -->
<!-- managed via the separate "Windows" modal so the save semantics here -->
<!-- stay simple — one PUT, no batching. -->
<div class="modal fade" id="itemEditModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil-square me-2"></i>
                    Edit item <code id="iem-code-label">—</code>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Description *</label>
                        <input type="text" class="form-control" id="iem-description" maxlength="255">
                    </div>
                    <div class="col-md-5">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Vendor code</label>
                        <input type="text" class="form-control" id="iem-vendor-code" maxlength="64">
                    </div>
                    <div class="col-md-7">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Vendor name</label>
                        <input type="text" class="form-control" id="iem-vendor-name" maxlength="160">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Tag</label>
                        <select class="form-select" id="iem-tag">
                            <option value="">—</option>
                            <option value="pcba">pcba</option>
                            <option value="swap">swap</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Status</label>
                        <select class="form-select" id="iem-status">
                            <option value="normal">normal</option>
                            <option value="new">new</option>
                            <option value="canceled">canceled</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Remark</label>
                        <input type="text" class="form-control" id="iem-remark" maxlength="255">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="iem-save">Save changes</button>
            </div>
        </div>
    </div>
</div>

<!-- ============ PHASE 9.1 — EDIT EXTENDED (ERP) FIELDS MODAL ============ -->
<!-- 7 ERP-sourced metadata fields. Populated from the ERP push (Phase 10) -->
<!-- when available; the modal exists for the gap-fill case where the      -->
<!-- operator gets the data via paper/email before the ERP sync runs.      -->
<div class="modal fade" id="itemExtendedFieldsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-tag me-2"></i>
                    ERP fields for <code id="iefm-code-label">—</code>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Product Family</label>
                        <input type="text" class="form-control" id="iefm-product-family" maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Trial ID</label>
                        <input type="text" class="form-control" id="iefm-trial-id" maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">From SubInventory</label>
                        <input type="text" class="form-control" id="iefm-from-sub" maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">To SubInventory</label>
                        <input type="text" class="form-control" id="iefm-to-sub" maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Location</label>
                        <input type="text" class="form-control" id="iefm-location" maxlength="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Phase</label>
                        <input type="text" class="form-control" id="iefm-phase" maxlength="50">
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Special Control</label>
                        <input type="text" class="form-control" id="iefm-special-control" maxlength="50">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="iefm-save">Save changes</button>
            </div>
        </div>
    </div>
</div>

<!-- ============ PHASE 10.4 — MANUAL ERP SYNC MODAL ============ -->
<!-- Admin-only. Operator picks a warehouse + (optional) backfill window, -->
<!-- POSTs to /api/admin/erp-sync/trigger, polls /jobs/{jobId} until       -->
<!-- terminal state, then closes with a toast. The richer status page     -->
<!-- (Phase 10.6) lives separately at /Admin/ErpSync.                     -->
<div class="modal fade" id="erpSyncModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Sync from ERP
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">
                    Pulls planning data from <code>BPI_PRS</code> for the chosen warehouse.
                    Closed pulls are protected; operator-edited fields are preserved.
                </p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Warehouse *</label>
                        <select class="form-select" id="erp-warehouse"></select>
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Backfill days</label>
                        <input type="number" class="form-control" id="erp-backfill-days" value="30" min="1" max="365">
                        <div class="form-text">DeliveryDate window. 30 days is the recurring default.</div>
                    </div>
                </div>
                <div id="erp-sync-status" class="mt-3" style="display: none;"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="erp-cancel">Cancel</button>
                <button type="button" class="btn btn-primary" id="erp-trigger">Start sync</button>
            </div>
        </div>
    </div>
</div>

<!-- ============ v2.1 PHASE 6.3 — WINDOWS MODAL ============ -->
<!-- Lives below an existing item. Each row mutation hits the matching -->
<!-- /windows[/{hour}] endpoint immediately — no batch save. -->
<div class="modal fade" id="windowsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-clock-history me-2"></i>
                    Windows for <code id="wm-code-label">—</code>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table windows-list-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 100px;">Hour</th>
                            <th style="width: 140px;">Expected</th>
                            <th style="width: 140px;">Received</th>
                            <th class="actions-col" style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="wm-tbody"></tbody>
                </table>
                <div class="border-top pt-3 mt-3 d-flex gap-2 align-items-end">
                    <div>
                        <label class="form-label small text-muted">Add: hour</label>
                        <select class="form-select form-select-sm" id="wm-new-hour" style="width: 100px;">
                            <!-- populated by JS to skip hours already in use -->
                        </select>
                    </div>
                    <div>
                        <label class="form-label small text-muted">Expected qty</label>
                        <input type="number" class="form-control form-control-sm" id="wm-new-qty" min="1" style="width: 120px;">
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="wm-add">
                        <i class="bi bi-plus-lg me-1"></i> Add window
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-host">
    <div class="custom-toast" id="toast">
        <div class="icon-wrap">✓</div>
        <div class="msg">
            <span id="toast-msg">—</span>
            <small id="toast-sub">—</small>
        </div>
    </div>
</div>

<script src="~/js/app-nav.js" asp-append-version="true"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/dashboard.js" asp-append-version="true"></script>

</body>
</html>

@functions {
    static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "??";
        var parts = name.Split(new[] { ' ', '.', '-' }, StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(p => char.ToUpperInvariant(p[0])));
    }
}
