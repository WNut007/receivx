@{
    ViewData["Title"] = "My Exports";
    ViewData["PageId"] = "exports";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Exports · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/exports.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/pagination.css" asp-append-version="true">
</head>
<body data-app-page="exports">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div>
                <div class="page-eyebrow">Activity · Exports</div>
                <h1 class="page-title">My Exports</h1>
                <p class="page-subtitle">Background exports you've queued. Download links expire after 24 hours.</p>
            </div>
            <div class="page-actions">
                @* Admin-only toggle. JS reveals via /api/auth/me. *@
                <label class="see-all-toggle" data-admin-only hidden>
                    <input type="checkbox" id="see-all"> See everyone's exports
                </label>
                <button class="btn btn-outline-secondary" id="btn-refresh" title="Refresh now">
                    <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
            </div>
        </div>

        <div class="section">
            <div class="section-head">
                <div class="section-title"><i class="bi bi-cloud-download"></i> Export jobs</div>
                <div class="meta-line" id="list-count">0 records</div>
            </div>

            <div id="auto-refresh-banner" class="auto-refresh-banner" hidden>
                <i class="bi bi-arrow-clockwise spin"></i>
                <span>A job is in flight — auto-refreshing every 5 s.</span>
            </div>

            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 130px;">Queued</th>
                            <th style="width: 110px;">Type</th>
                            <th style="width: 110px;">Status</th>
                            <th class="requester-col" style="width: 200px;">Requester</th>
                            <th style="width: 100px;" class="num">Rows</th>
                            <th>File / error</th>
                            <th style="width: 110px;">Completed</th>
                            <th style="width: 100px; text-align: right;">Action</th>
                        </tr>
                    </thead>
                    <tbody id="exports-tbody">
                        <tr><td colspan="8" class="empty-row">
                            <i class="bi bi-hourglass-split"></i> Loading…
                        </td></tr>
                    </tbody>
                </table>
            </div>

            <div id="exports-pagination" class="pagination" hidden></div>
        </div>
    </div>
</div>

<script src="~/js/app-nav.js" asp-append-version="true"></script>
<script src="~/js/components/pagination.js" asp-append-version="true"></script>
<script src="~/js/exports.js" asp-append-version="true"></script>
</body>
</html>
