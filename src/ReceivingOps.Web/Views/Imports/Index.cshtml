@{
    ViewData["Title"] = "Imports";
    ViewData["PageId"] = "imports";
    Layout = null;
    var canUpload = (bool)(ViewData["CanUpload"] ?? false);
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Imports · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/exports.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/imports.css" asp-append-version="true">
</head>
<body data-app-page="imports">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div>
                <div class="page-eyebrow">Data · Imports</div>
                <h1 class="page-title">Imports</h1>
                <p class="page-subtitle">Bulk-import purchase orders from an Excel workbook. Header row + per-row validation runs first; review and confirm before the rows commit.</p>
            </div>
        </div>

@if (canUpload)
{
        <section class="section" id="imports-uploader-section">
            <div class="section-body">
                <div class="imports-dropzone" id="imports-dropzone">
                    <input type="file" id="imports-file-input" accept=".xls,.xlsx" hidden>
                    <i class="bi bi-cloud-upload imports-dropzone-icon"></i>
                    <p class="imports-dropzone-primary">Drop your PO Excel workbook here</p>
                    <p class="imports-dropzone-secondary">.xls or .xlsx · max 50 MB</p>
                    <button type="button" class="btn btn-outline-secondary" id="imports-browse-btn">
                        <i class="bi bi-folder2-open"></i> Browse files…
                    </button>
                </div>

                <div id="imports-preview-panel" class="imports-panel" hidden>
                    <div class="imports-panel-head">
                        <h3>Review import</h3>
                        <p class="imports-panel-filename" id="imports-preview-filename"></p>
                    </div>
                    <div id="imports-preview-summary"></div>
                    <div id="imports-preview-errors"></div>
                    <div class="imports-panel-actions">
                        <button type="button" class="btn btn-outline-secondary" id="imports-cancel-btn">
                            Cancel
                        </button>
                        <button type="button" class="btn btn-primary" id="imports-confirm-btn">
                            <i class="bi bi-check2-circle"></i> Confirm import
                        </button>
                    </div>
                </div>

                <div id="imports-status-panel" class="imports-panel" hidden>
                    <div class="imports-panel-head">
                        <h3>Status</h3>
                        <p class="imports-panel-filename" id="imports-status-filename"></p>
                    </div>
                    <div id="imports-status-body"></div>
                    <div class="imports-panel-actions" id="imports-status-actions" hidden>
                        <button type="button" class="btn btn-primary" id="imports-new-btn">
                            <i class="bi bi-arrow-counterclockwise"></i> New import
                        </button>
                    </div>
                </div>
            </div>
        </section>
}
else
{
        <section class="section" id="imports-operator-notice">
            <div class="section-body">
                <div class="imports-notice">
                    <i class="bi bi-info-circle imports-notice-icon"></i>
                    <div>
                        <h3>Importing is admin- or supervisor-only</h3>
                        <p>Bulk PO imports change purchase-order data across the warehouse, so only admins and supervisors can run them. If you have a workbook to load, hand it to your warehouse supervisor — or ask an admin to add the supervisor role to your account.</p>
                    </div>
                </div>
            </div>
        </section>
}
    </div>
</div>
@if (canUpload)
{
    <script src="~/js/imports.js" asp-append-version="true"></script>
}
<script src="~/js/app-nav.js" asp-append-version="true"></script>
</body>
</html>
