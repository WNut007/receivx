@{
    ViewData["Title"] = "Delivery Order";
    ViewData["PageId"] = "reports";
    Layout = null;
    var pullId = ViewData["PullId"];
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delivery Order · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    <style>
        body { background: var(--bg, #f6f5f1); color: var(--text, #1a1d20); font-family: 'Roboto', sans-serif; }
        .page-wrap { padding: 24px 32px; max-width: 1200px; margin: 0 auto; }
        .page-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 24px; }
        .page-eyebrow { font-family: 'Roboto Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: #5a626c; margin-bottom: 6px; }
        .page-title { font-size: 24px; font-weight: 500; margin: 0; }
        .page-actions a, .page-actions button { margin-left: 8px; }
        /* Embed the PDF directly — the browser's built-in PDF viewer
           handles zoom/scroll/print. FastReport.OpenSource.Web does not
           ship the JS viewer assets (only the commercial FastReport.Web
           package does), so the PDF iframe is the simplest reliable
           preview path. */
        .report-host {
            background: #fff;
            border: 0.5px solid #e6e3dc;
            border-radius: 10px;
            padding: 0;
            overflow: hidden;
        }
        .report-host iframe {
            display: block;
            width: 100%;
            height: calc(100vh - 180px);
            min-height: 600px;
            border: 0;
        }
    </style>
</head>
<body data-app-page="reports">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div>
                <div class="page-eyebrow">Audit · Delivery Order</div>
                <h1 class="page-title">DO Preview</h1>
            </div>
            <div class="page-actions">
                <a class="btn btn-outline-secondary btn-sm" href="/Reports">
                    <i class="bi bi-arrow-left"></i> Back to list
                </a>
                <a class="btn btn-primary btn-sm" href="/Reports/Do/@ViewData["PullId"]/pdf" title="Download the DO as PDF">
                    <i class="bi bi-download"></i> Download PDF
                </a>
            </div>
        </div>
        <div class="report-host">
            <iframe src="/Reports/Do/@pullId/pdf#toolbar=1&navpanes=0&zoom=page-fit"
                    title="Delivery Order PDF preview"></iframe>
        </div>
    </div>
</div>
<script src="~/js/app-nav.js" asp-append-version="true"></script>
</body>
</html>
