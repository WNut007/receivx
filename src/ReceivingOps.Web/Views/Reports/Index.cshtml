@model ReceivingOps.Web.Models.PaginatedResponse<ReceivingOps.Web.Models.Dtos.PullSummary>
@{
    ViewData["Title"] = "Reports";
    ViewData["PageId"] = "reports";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/components/pagination.css" asp-append-version="true">
</head>
<body data-app-page="reports">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div class="page-eyebrow">Audit · Delivery Orders</div>
            <h1 class="page-title">Reports</h1>
            <p class="page-subtitle">Closed pulls with delivery activity. Click a row to preview the DO or export PDF.</p>
        </div>

        <div class="reports-filter-bar">
            <input type="text" class="form-control filter-q" placeholder="Search PO number, item code…">
            <input type="text" class="form-control filter-pull" placeholder="Pull number">
            <select class="form-select filter-date-range" id="filter-date-range" title="Filter by ClosedAt">
                <option value="all">All dates</option>
                <option value="today">Today</option>
                <option value="last_2_days" selected>Last 2 days</option>
                <option value="yesterday">Yesterday</option>
                <option value="this_week">This week</option>
                <option value="last_week">Last week</option>
                <option value="custom">Custom range…</option>
            </select>
            <select class="form-select filter-wh">
                <option value="">All warehouses</option>
                @* Warehouse options populated client-side from /api/warehouses *@
            </select>
            <span class="result-count" id="result-count">@Model.Items.Count of @Model.Total pull@(Model.Total == 1 ? "" : "s")</span>
        </div>
        <div class="reports-custom-date-row" id="reports-custom-date-row" hidden>
            <span class="date-label">From</span>
            <input type="date" class="form-control filter-from" id="filter-from">
            <span class="date-arrow"><i class="bi bi-arrow-right"></i></span>
            <span class="date-label">To</span>
            <input type="date" class="form-control filter-to" id="filter-to">
        </div>

        <div class="reports-split">
            <aside class="reports-list-pane">
                <div class="list-header">CLOSED PULLS</div>
                <ul class="pull-rows" id="pull-rows">
                    @if (Model.Items.Count == 0)
                    {
                        <li class="list-empty">
                            @(Model.Total == 0
                                ? "No closed pulls with delivery activity yet. Close a pull (Receive → Close) with at least one non-cancelled receipt and it will appear here."
                                : $"No pulls on page {Model.Page}. Total = {Model.Total} across {Model.TotalPages} page(s).")
                        </li>
                    }
                    else
                    {
                        @foreach (var p in Model.Items)
                        {
                            <li class="pull-row"
                                data-pull-id="@p.Id"
                                data-pull-number="@p.PullNumber"
                                data-warehouse-id="@p.WarehouseId"
                                data-closed-at="@(p.ClosedAt?.ToString("yyyy-MM-dd") ?? "")">
                                <div class="row-top">
                                    <span class="pull-number">@p.PullNumber</span>
                                    @if (p.LockPoByPull)
                                    {
                                        <span class="pull-lock-badge" title="PO allocation locked to this pull">PO LOCK</span>
                                    }
                                </div>
                                <div class="row-meta">
                                    <span title="Pull date">@p.PullDate.ToString("yyyy-MM-dd")</span>
                                    <span>@p.WarehouseCode</span>
                                </div>
                                <div class="row-stats">
                                    <span>Items <b>@p.ItemCount</b></span>
                                    <span>Qty <b>@p.TotalReceived.ToString("N0")</b></span>
                                    @if (!string.IsNullOrEmpty(p.ReferenceNumber))
                                    {
                                        <span title="Reference: @p.ReferenceNumber"><i class="bi bi-paperclip"></i></span>
                                    }
                                </div>
                            </li>
                        }
                    }
                </ul>
                @await Html.PartialAsync("_Pagination", new ReceivingOps.Web.Models.PaginationPartialModel
                {
                    Page = Model.Page,
                    PageSize = Model.PageSize,
                    Total = Model.Total,
                    BaseQuery = Context.Request.QueryString.HasValue ? Context.Request.QueryString.Value : "",
                    Label = "closed pulls",
                })
            </aside>

            <main class="reports-preview-pane">
                <div class="preview-toolbar">
                    <div class="preview-title" id="preview-title">SELECT A PULL TO PREVIEW</div>
                    <div class="preview-actions">
                        <button class="btn btn-outline-secondary btn-print" id="btn-print" disabled>
                            <i class="bi bi-printer"></i> Print
                        </button>
                        <button class="btn btn-primary btn-export-pdf" id="btn-export-pdf" disabled>
                            <i class="bi bi-download"></i> Export PDF
                        </button>
                    </div>
                </div>
                <div class="preview-body" id="preview-body">
                    <div class="preview-empty">Click a pull from the left to see its delivery orders.</div>
                </div>
            </main>
        </div>
    </div>
</div>
<script src="~/js/app-nav.js" asp-append-version="true"></script>
<script src="~/js/reports.js" asp-append-version="true"></script>
</body>
</html>
