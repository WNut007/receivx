@model IReadOnlyList<ReceivingOps.Web.Models.Dtos.PullSummary>
@{
    ViewData["Title"] = "Reports";
    ViewData["PageId"] = "reports";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports · Receiving Operations</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@@300;400;500;600;700;900&family=Roboto+Mono:wght@@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
    <style>
        /* v2.x Phase 7.3 — local-only styles for the Reports list. Lives in
           the view because no other page references these rules; promote to
           a separate stylesheet if the surface grows. */
        body { background: var(--bg, #f6f5f1); color: var(--text, #1a1d20); font-family: 'Roboto', sans-serif; }
        .page-wrap { padding: 24px 32px; max-width: 1200px; margin: 0 auto; }
        .page-head { margin-bottom: 24px; }
        .page-eyebrow { font-family: 'Roboto Mono', monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; color: #5a626c; margin-bottom: 6px; }
        .page-title { font-size: 28px; font-weight: 500; margin: 0 0 8px 0; }
        .page-subtitle { color: #5a626c; font-size: 13px; margin: 0; }
        .reports-table {
            width: 100%;
            background: #fff;
            border: 0.5px solid #e6e3dc;
            border-radius: 10px;
            border-collapse: separate;
            border-spacing: 0;
            overflow: hidden;
        }
        .reports-table thead th {
            font-family: 'Roboto Mono', monospace;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #5a626c;
            font-weight: 600;
            padding: 12px 14px;
            border-bottom: 1px solid #e6e3dc;
            text-align: left;
        }
        .reports-table tbody td {
            padding: 12px 14px;
            border-bottom: 1px solid #f0eee8;
            font-size: 13px;
            vertical-align: middle;
        }
        .reports-table tbody tr:last-child td { border-bottom: none; }
        .reports-table tbody tr:hover { background: #faf9f6; }
        .pull-num { font-family: 'Roboto Mono', monospace; font-weight: 600; }
        .actions a { margin-right: 8px; font-size: 12px; }
        .empty {
            background: #fff;
            border: 1px dashed #d4d0c6;
            border-radius: 10px;
            padding: 40px;
            text-align: center;
            color: #5a626c;
        }
    </style>
</head>
<body data-app-page="reports">
<div class="app">
    <!-- nav injected by app-nav.js -->
    <div class="page-wrap">
        <div class="page-head">
            <div class="page-eyebrow">Audit · Delivery Orders</div>
            <h1 class="page-title">Reports</h1>
            <p class="page-subtitle">Closed pulls with delivery activity. Click a row to preview the DO or export PDF.</p>
        </div>

        @if (Model.Count == 0)
        {
            <div class="empty">
                No closed pulls with delivery activity yet. Close a pull (Receive → Close)
                with at least one non-cancelled receipt and it will appear here.
            </div>
        }
        else
        {
            <table class="reports-table">
                <thead>
                    <tr>
                        <th>Pull #</th>
                        <th>Date</th>
                        <th>Warehouse</th>
                        <th>Reference</th>
                        <th class="text-end">Received</th>
                        <th>Closed by</th>
                        <th class="actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model)
                    {
                        <tr>
                            <td><span class="pull-num">@p.PullNumber</span></td>
                            <td>@p.PullDate.ToString("yyyy-MM-dd")</td>
                            <td>@p.WarehouseCode · @p.WarehouseName</td>
                            <td>@(string.IsNullOrEmpty(p.ReferenceNumber) ? "—" : p.ReferenceNumber)</td>
                            <td class="text-end">@p.TotalReceived.ToString("N0")</td>
                            <td>@(p.ClosedByName ?? "—")</td>
                            <td class="actions">
                                <a href="/Reports/Do/@p.Id" title="Open the DO preview"><i class="bi bi-eye"></i> Preview</a>
                                <a href="/Reports/Do/@p.Id/pdf" title="Download the DO as PDF"><i class="bi bi-download"></i> PDF</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
<script src="~/js/app-nav.js" asp-append-version="true"></script>
</body>
</html>
