@model ReceivingOps.Web.Models.Dtos.DoReportData
@*
   Delivery Order HTML preview — DSV-style Delivery Note layout.

   One <article> per DoOrder. DoOrder identity = the 4-tuple
   (VendorCode × SubInventory × ToLocation × InvoiceNo). A pull may spawn
   multiple DOs when its receipts span multiple vendors, source sub-
   inventories, destination locations, or invoices.

   The page mirrors the FastReport PDF layout authored by
   DeliveryOrderTemplateBuilder (Path B Stages 3–6): header strip with
   warehouse logo + DELIVERY NOTE + DN# (right), address strip, 5-row
   info grid (P/O · PRS · order-type · drop-id · date  ||  vendor-id ·
   vendor · from · to · invoice), 4 Code128 barcodes (PO · PRS · DN ·
   INVOICE), items table, TOTAL QTY + barcode, STORING NOTE strip, two
   empty signature boxes for manual signing.

   Browser barcodes are text placeholders (.dsv-barcode-placeholder) —
   value-only, no scannable bars. The PDF carries the real Code128 bars
   via FastReport BarcodeObject. If JsBarcode (or similar) gets wired in
   later, swap the placeholder divs for <svg> hooks and load the lib
   from Views/Reports/Index.cshtml.

   All colors via CSS variables so theme switches reflow without re-render.
*@
@{
    string Dash(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s!;
}
@foreach (var order in Model.Orders)
{
    var dateOfDelivery = Model.Pull.ClosedAt?.ToString("dd MMM yyyy") ?? "—";
    var dateReceived   = order.LastReceivedAt?.ToString("dd MMM yyyy HH:mm") ?? "—";
    var dnPlusInv = string.IsNullOrWhiteSpace(order.InvoiceNo)
        ? order.DeliveryNoteNo
        : $"{order.DeliveryNoteNo}+{order.InvoiceNo}";

    <article class="dsv-do">
        <header class="dsv-top">
            @if (!string.IsNullOrWhiteSpace(Model.Pull.WarehouseLogoDataUrl))
            {
                <img class="dsv-logo" src="@Model.Pull.WarehouseLogoDataUrl" alt="@(Model.Pull.WarehouseCode) logo" />
            }
            else
            {
                <div class="dsv-logo dsv-logo-fallback">@Model.Pull.WarehouseCode</div>
            }
            <div class="dsv-title">DELIVERY NOTE</div>
            <div class="dsv-dn">
                <div class="dsv-dn-label">Delivery Note No.</div>
                <div class="dsv-dn-value">@order.DeliveryNoteNo</div>
            </div>
        </header>

        <section class="dsv-address-strip">
            <div class="dsv-warehouse">
                <div class="dsv-wh-codename">@Model.Pull.WarehouseCode · @Model.Pull.WarehouseName</div>
                @if (!string.IsNullOrWhiteSpace(Model.Pull.WarehouseAddress))
                {
                    <div class="dsv-wh-address">@Model.Pull.WarehouseAddress</div>
                }
            </div>
            <div class="dsv-deliver-to">
                <div class="dsv-block-label">DELIVERY TO</div>
                <div class="dsv-block-value">@(string.IsNullOrWhiteSpace(Model.Pull.WarehouseAddress) ? Model.Pull.WarehouseName : Model.Pull.WarehouseAddress)</div>
            </div>
        </section>

        <section class="dsv-info-grid">
            <dl class="dsv-info-col">
                <dt>P/O NO</dt>           <dd>@Dash(order.HeaderPoNumber)</dd>
                <dt>PRS NO</dt>           <dd>@Model.Pull.PullNumber</dd>
                <dt>ORDER TYPE</dt>       <dd>—</dd>
                <dt>DROP ID</dt>          <dd>—</dd>
                <dt>DATE OF DELIVERY</dt> <dd>@dateOfDelivery</dd>
            </dl>
            <dl class="dsv-info-col">
                <dt>VENDOR ID</dt>      <dd>@Dash(order.VendorCode)</dd>
                <dt>VENDOR</dt>         <dd>@Dash(order.VendorName ?? order.VendorCode)</dd>
                <dt>FROM</dt>           <dd>@Dash(order.SubInventory)</dd>
                <dt>TO</dt>             <dd>@Dash(order.ToLocation)</dd>
                <dt>VENDOR INVOICE</dt> <dd>@Dash(order.InvoiceNo)</dd>
            </dl>
        </section>

        @* Browser preview shows the values destined for the PDF's four
           Code128 barcodes (P/O NO, PRS NO, DELIVERY NOTE, INVOICE). The
           actual barcode bars live in the PDF; HTML carries values only.
           Section is always emitted with a fixed 4-column grid so the
           header layout doesn't reflow when one of the values is null. *@
        <section class="dsv-barcodes">
            <div class="dsv-barcode">
                <div class="dsv-barcode-caption">P/O NO</div>
                <div class="dsv-barcode-placeholder mono">@Dash(order.HeaderPoNumber)</div>
            </div>
            <div class="dsv-barcode">
                <div class="dsv-barcode-caption">PRS NO</div>
                <div class="dsv-barcode-placeholder mono">@Dash(Model.Pull.PullNumber)</div>
            </div>
            <div class="dsv-barcode">
                <div class="dsv-barcode-caption">DELIVERY NOTE</div>
                <div class="dsv-barcode-placeholder mono">@Dash(order.DeliveryNoteNo)</div>
            </div>
            <div class="dsv-barcode">
                <div class="dsv-barcode-caption">INVOICE</div>
                <div class="dsv-barcode-placeholder mono">@Dash(order.InvoiceNo)</div>
            </div>
        </section>

        <section class="dsv-lines">
            <table>
                <thead>
                    <tr>
                        <th class="col-part">PART NUMBER</th>
                        <th class="col-desc">DESCRIPTION</th>
                        <th class="col-pallet">PALLET</th>
                        <th class="col-kanban">KANBAN</th>
                        <th class="col-asn">ASN</th>
                        <th class="col-round">ROUND</th>
                        <th class="col-po">PO</th>
                        <th class="col-qty num">QTY</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var line in order.Lines)
                    {
                        <tr>
                            <td class="mono">@line.ItemCode</td>
                            <td>@line.Description</td>
                            <td class="mono">@Dash(line.PalletId)</td>
                            <td class="mono">@Dash(line.KanbanNo)</td>
                            <td class="mono">@Dash(line.AsnNo)</td>
                            <td class="mono">@Dash(line.OrderRound)</td>
                            <td class="mono">@Dash(line.SourcePoNo)</td>
                            <td class="num"><b>@line.TotalQty.ToString("N0")</b></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="7" class="dsv-total-label">TOTAL QTY</td>
                        <td class="num dsv-total-value">@order.TotalQty.ToString("N0")</td>
                    </tr>
                </tfoot>
            </table>
            @* Stage 5 parity — TOTAL QTY barcode placeholder beneath the
               table mirrors the .frx OrderFooter BcTotal at (124, 11, 56, 10).
               Text-only for now; PDF carries the Code128 bars. *@
            <div class="dsv-total-barcode">
                <div class="dsv-barcode-caption">TOTAL QTY</div>
                <div class="dsv-barcode-placeholder mono">@order.TotalQty.ToString("N0")</div>
            </div>
        </section>

        <footer class="dsv-footer">
            <div class="dsv-storing-note">
                <div class="dsv-storing-title">STORING NOTE</div>
                <div class="dsv-storing-grid">
                    <div><label>Date Received</label><span>@dateReceived</span></div>
                    <div><label>Delivery Note No + Inv</label><span class="mono">@dnPlusInv</span></div>
                </div>
            </div>
            @await Html.PartialAsync("~/Views/Reports/_SignatureBoxes.cshtml", Model.Pull)
        </footer>
    </article>
}
