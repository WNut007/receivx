@*
    Phase 13.8.2 — shared trigger modal for /Admin/ErpSync + Dashboard.
    Renders Bootstrap 5.3 modal markup parameterized by Model.ModalId +
    Model.FieldPrefix so both consumer pages stay structurally identical.

    New in 13.8: SOURCE dropdown above Warehouse — populated client-side
    by erp-source-dropdown.js (13.8.3) from the per-source Enabled flags
    in /api/admin/config/sections/ErpSync. The "from <code>...</code>"
    label updates live to match the selection.
*@
@model ReceivingOps.Web.Models.ErpSyncTriggerModalModel
<div class="modal fade" id="@Model.ModalId" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-arrow-repeat me-2"></i>
                    Trigger ERP sync
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">
                    Pulls planning data from
                    <code id="@(Model.FieldPrefix)-source-label">all enabled sources</code>
                    using each source's configured warehouse + backfill window.
                    Closed pulls are protected; operator-edited fields are preserved.
                </p>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small text-muted text-uppercase fw-semibold" style="letter-spacing: 0.1em;">Source *</label>
                        <select class="form-select erp-source-select" id="@(Model.FieldPrefix)-source">
                            @* Options injected by erp-source-dropdown.js when the modal opens. *@
                        </select>
                        <div class="form-text">
                            Per-source warehouse + backfill come from
                            <a href="/Config" class="text-decoration-none">/Config &rarr; Sync Schedule</a>
                            (restart required after edits).
                        </div>
                    </div>
                </div>
                <div id="@(Model.FieldPrefix)-status" class="mt-3" hidden></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="@(Model.FieldPrefix)-cancel">Cancel</button>
                <button type="button" class="btn btn-primary" id="@(Model.FieldPrefix)-trigger">Start sync</button>
            </div>
        </div>
    </div>
</div>
